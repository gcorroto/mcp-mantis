# --- Mantis REST API ---------------------------------------------------------
# Full REST base URL, INCLUDING index.php (needed when URL rewriting is disabled on the host).
MANTIS_REST_BASE_URL=https://mantis.example.com/api/rest/index.php

# API token from Mantis: My Account -> API Tokens -> Create.
# Sent verbatim as the `Authorization` header. Keep it secret; never commit .env.
MANTIS_TOKEN=

# Read/write mode. Default false (writes enabled) — this server is for issue resolvers
# (status changes, notes, assignment). Set true for a strictly read-only deployment.
MANTIS_READONLY=false

# --- Semantic search (optional, local ML) ------------------------------------
# Local natural-language search over issues via @huggingface/transformers.
MANTIS_SEARCH_ENABLED=true
# MANTIS_SEARCH_DIR=            # default: ~/.cache/mcp-mantis/search
# MANTIS_SEARCH_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# MANTIS_SEARCH_THREADS=1

# --- Optional tuning ---------------------------------------------------------
# MANTIS_TIMEOUT_MS=30000
# MANTIS_METADATA_TTL_MS=300000
# MANTIS_DEFAULT_PAGE_SIZE=50
# MANTIS_MAX_PAGE_SIZE=200

# --- HTTP health server (optional, only for `npm run dev` / `npm start`) ------
PORT=3000
HOST=127.0.0.1
